# ── Core ─────────────────────────────────────────────────────────────────────
APP_ENV=dev
APP_DEBUG=true

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_DB=finpulse
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=finpulse
# DSN used by the api service (host = docker-compose service name)
DATABASE_DSN=pgsql:host=db;port=5432;dbname=finpulse
DATABASE_USER=finpulse
DATABASE_PASSWORD=finpulse

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=tcp://redis:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Change this in any non-local environment.
JWT_SECRET=change-me-in-production
JWT_TTL=3600

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# ── AI worker ─────────────────────────────────────────────────────────────────
# Internal URL of the ai-worker (docker-compose service name).
AI_WORKER_URL=http://ai-worker:8000
# Provider: fake | gemini | claude | openai
# "fake" returns deterministic answers and needs NO credentials (default demo).
LLM_PROVIDER=fake
LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── BACEN ─────────────────────────────────────────────────────────────────────
BACEN_BASE_URL=https://api.bcb.gov.br
# Cache TTL (seconds) for fetched series.
BACEN_CACHE_TTL=3600
